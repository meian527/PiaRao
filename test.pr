type Person = record name age {
    introduce self = println("I am ", self.name, " ", self.age, " years old, I am human");
};
type Animal = record name kind {
    introduce self = println("My kind is ", self.kind, " I am animal");
};
let intro thing = thing.introduce();

let person = Person "jack" 16;
let animal = Animal "peppa" "Pig";
(Person "Li hua" 17).introduce();
intro person;
intro animal;

println type_info(intro).equ("Object");
